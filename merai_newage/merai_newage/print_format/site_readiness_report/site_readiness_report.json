 "html": "<div class=\"page-header\" style=\"margin-bottom:10px; position:relative;\">\n<table class=\"no-border-header\" style=\"width:100%; text-align:center;\">\n        <thead>\n            <tr>\n                <td style=\"width: 20%; text-align: left; border: none;\">\n                    <img src=\"/files/Meril Logo.svg\" alt=\"Test\" width=\"110px\" height=\"70px\">\n                </td>\n                <td style=\"width: 55%; text-align: center; border: none;\">\n                    <div style=\"display: flex; flex-direction: column; justify-content: center; align-items: center;\" class=\"title\">\n                                  <h3><b>SITE READINESS REPORT</b></h3>\n                    </div>\n                </td>\n                <td style=\"width: 25%; text-align: center; vertical-align: middle !important; border: none;\">\n                                  \n                </td>\n            </tr>\n        </thead>\n    </table>\n</div>\n\n\n<style>\n    body {\n        font-family: Arial, sans-serif;\n        font-size: 12px;\n    }\n    table {\n        width: 100%;\n        border-collapse: collapse;\n        margin-bottom: 15px;\n    }\n    th, td {\n        border: 1px solid #000;\n        padding: 6px;\n        text-align: center;\n\n        \n    }\n    th {\n        background: #f2f2f2;\n        text-align: center;\n\n    }\n    .section-title {\n        font-weight: bold;\n        margin: 10px 0 5px;\n        font-size: 15px;\n    }\n</style>\n\n<br>\n<!-- 1. Customer Details -->\n<div class=\"section-title\">1. Customer / Hospital Details</div>\n<table>\n    <tr>\n        <th width=\"3%\">Sl.</th>\n        <th width=\"40%\">Description</th>\n        <th>Details</th>\n    </tr>\n    <tr>\n        <td>a</td>\n        <td style=\"text-align: left;\">Customer / Hospital Name</td>\n        <td>{{ doc.customer__hospital_name or \"\" }}</td>\n    </tr>\n    <tr>\n        <td>b</td>\n        <td style=\"text-align: left;\">System Serial No.</td>\n        <td>{{ doc.system_serial_no or \"\" }}</td>\n    </tr>\n    <tr>\n        <td>c</td>\n        <td style=\"text-align: left;\">Installation Site Address</td>\n        <td>{{ doc.installation_site_address or \"\" }}</td>\n    </tr>\n    <tr>\n        <td>d</td>\n        <td style=\"text-align: left;\">Salesperson Name & Contact</td>\n        <td>\n            {{ doc.salesperson_name or \"\" }}  {{ doc.salesperson_contact or \"\" }}\n        </td>\n    </tr>\n    <tr>\n        <td>e</td>\n        <td style=\"text-align: left;\">Local TAS Name & Contact</td>\n        <td>\n            {{ doc.local_tas_name or \"\" }}  {{ doc.local_tas_contact or \"\" }}\n        </td>\n    </tr>\n</table>\n\n\n<!-- 2. Power Testing -->\n<div class=\"section-title\">2. Power Testing</div>\n<table>\n    <tr>\n        <th width=\"3%\">Sl.</th>\n        <th width=\"30%\">Test Parameters</th>\n        <th width=\"20%\">Standard Limit</th>\n        <th width=\"20%\">Measured Value</th>\n        <th>Result</th>\n        <th>Remarks</th>\n    </tr>\n    {% for row in doc.power_testing %}\n    <tr>\n        <td>{{ loop.index }}</td>\n        <td style=\"text-align:left;\">{{ row.test_parameters }}</td>\n        <td>{{ row.standard_limit }}</td>\n        <td>{{ row.measured_value }}</td>\n        <td>{{ row.result }}</td>\n        <td>{{ row.remarks }}</td>\n    </tr>\n    {% endfor %}\n</table>\n<!-- 3. Pre Installation -->\n<div class=\"section-title\">3. Pre-Installation Activities</div>\n<table>\n    <tr>\n        <th>Sl.</th>\n        <th width=\"30%\">Activity</th>\n        <th width=\"20%\">Responsible</th>\n        <th width=\"20%\">Tentative Date & Time</th>\n        <th>Remarks</th>\n    </tr>\n    {% for row in doc.pre_installation_table %}\n    <tr>\n        <td>{{ loop.index }}</td>\n        <td style=\"text-align:left;\">{{ row.activity or \"\" }}</td>\n        <td>{{ row.responsible or \"\" }}</td>\n        <td>{{ frappe.utils.format_datetime(row.tentative_datetime, \"dd-MM-yyyy hh:mm:ss a\") if row.tentative_datetime else \"\" }}</td>\n        <td>{{ row.remarks or \"\" }}</td>\n    </tr>\n    {% endfor %}\n</table>\n\n\n<!-- 4. Sawbone Testing -->\n<div class=\"section-title\">4. Sawbone Testing Plan</div>\n<table>\n    <tr>\n        <th>Sl.</th>\n        <th width=\"30%\">Activity</th>\n        <th width=\"20%\">Responsible</th>\n        <th width=\"20%\">Tentative Date & Time</th>\n        <th>Remarks</th>\n    </tr>\n    {% for row in doc.sawbone_testing %}\n    <tr>\n        <td>{{ loop.index }}</td>\n        <td style=\"text-align:left;\">{{ row.activity or \"\"}}</td>\n        <td>{{ row.responsible or \"\"}}</td>\n        <td>{{ frappe.utils.format_datetime(row.tentative_datetime, \"dd-MM-yyyy hh:mm:ss a\") if row.tentative_datetime else \"\" }}</td>\n        <td>{{ row.remarks or \"\"}}</td>\n    </tr>\n    {% endfor %}\n</table>\n\n<!-- 5. Closure -->\n<div class=\"section-title\">5. Closure Activities</div>\n<table>\n    <tr>\n        <th>Sl.</th>\n        <th width=\"30%\">Activity</th>\n        <th width=\"20%\">Responsible</th>\n        <th width=\"20%\">Tentative Date & Time</th>\n        <th>Remarks</th>\n    </tr>\n    {% for row in doc.closure_activity %}\n    <tr>\n        <td>{{ loop.index }}</td>\n        <td style=\"text-align:left;\">{{ row.activity or \"\" }}</td>\n        <td>{{ row.responsible or \"\" }}</td>\n        <td>{{ frappe.utils.format_datetime(row.tentative_datetime, \"dd-MM-yyyy hh:mm:ss a\") if row.tentative_datetime else \"\" }}</td>\n        <td>{{ row.remarks or \"\" }}</td>\n    </tr>\n    {% endfor %}\n</table>\n\n<!-- 6. Checklist -->\n<div class=\"section-title\">6. Sales Team Responsibility Checklist</div>\n<ul>\n    <li>Confirm surgeon & biomedical team availability.</li>\n    <li>Share tentative installation schedule in advance with all stakeholders.</li>\n    <li>Coordinate OT readiness for MISSO installation.</li>\n</ul>",
